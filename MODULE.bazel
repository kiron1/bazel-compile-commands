bazel_dep(name = "rules_python", version = "1.9.0")
bazel_dep(name = "rules_shell", version = "0.8.0")
bazel_dep(name = "rules_swift", version = "3.5.0", repo_name = "build_bazel_rules_swift")

# ERROR: Error computing the main repository mapping: rules_apple@4.5.3 depends on rules_swift@3.5.0
# with compatibility level 3, but grpc@1.80.0 depends on rules_swift@2.5.0 with compatibility level 2
# which is different
single_version_override(
    module_name = "rules_swift",
    version = "3.5.0",
)

bazel_dep(name = "llvm", version = "0.7.3")

register_toolchains("@llvm//toolchain:all")

# https://github.com/protocolbuffers/protobuf/issues/22073#issuecomment-2936499960
bazel_dep(name = "abseil-cpp", version = "20250814.2", repo_name = None)

bazel_dep(name = "googletest", version = "1.17.0.bcr.2", dev_dependency = True, repo_name = "com_google_googletest")

apple_cc_configure = use_extension(
    "@build_bazel_apple_support//crosstool:setup.bzl",
    "apple_cc_configure_extension",
)
use_repo(apple_cc_configure, "local_config_apple_cc")

